# Anthropic (Claude) — powers field generation ("the Writer")
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Used only for seo_title/meta_description (short, mechanical, character-capped) — not narrative fields.
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5

# OpenAI (GPT) — powers evaluation ("the Editorial Director")
# Verify this model name against your current OpenAI account/catalog before relying on it.
# To cut evaluation cost ~16x, try OPENAI_MODEL=gpt-4o-mini — validate scoring quality on a sample
# of real fields first (compare scores/feedback against gpt-4o) before relying on it in production.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Backend server
PORT=4000

# Neon (hosted Postgres) connection string — Neon dashboard > your project > Connection Details.
# Must include ?sslmode=require. The server will not start without this set.
DATABASE_URL=

# Minimum GPT overall score (0-10) to accept a Claude draft without an improve pass
EDITORIAL_SCORE_THRESHOLD=7.5

# Approximate USD->INR rate for the ₹ cost estimates — drifts with the market, update periodically
USD_TO_INR_RATE=96

# WordPress — used only by the Admin's "Publish to WordPress" action (server/integrations/wordpressClient.js).
# Leave blank until ready to test; the publish endpoint returns a clear error naming which var is missing
# rather than silently failing.
# No trailing slash, e.g. https://degreebaba.com
WORDPRESS_SITE_URL=
# WP Admin > Users > your profile > Application Passwords > add a new one. Use that, never your real login password.
WORDPRESS_APP_USER=
WORDPRESS_APP_PASSWORD=
# REST base slug per page type (hits wp-json/wp/v2/<slug>) — adjust to match your site's actual custom post type slugs.
WORDPRESS_POST_TYPE_UNIVERSITY=universities
WORDPRESS_POST_TYPE_COURSE=courses
WORDPRESS_POST_TYPE_SPECIALIZATION=specializations
